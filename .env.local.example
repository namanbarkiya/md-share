# Copy to .env.local and fill in values from your Supabase project dashboard.
# Settings → API Keys (the new sb_publishable_* / sb_secret_* format).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxx

# Public site URL — used to build OAuth redirect URLs in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
